---
import { Icon } from "astro-icon/components";

interface Props {
    title: string;
    subtitle: string;
    href: string;
    leadingIcon?: string;
}

const { title, subtitle, href, leadingIcon } = Astro.props;
---

<div
    class="block p-6 bg-card rounded-lg hover:bg-accent has-[span:hover]:bg-card dark:outline transition-colors relative group overflow-hidden"
>
    <a href={href} class="absolute inset-0 z-10" aria-label="Tile Link"></a>

    <div class="flex flex-row relative items-center">
        <!-- Leading -->
        <div class="mr-6 text-card-foreground">
            <Icon name={leadingIcon || "mdi:link"} size="32" />
        </div>

        <!-- Title and Subtitle -->
        <div class="flex flex-col relative">
            <div class="font-semibold font-serif">{title}</div>
            <div class="text-card-foreground">{subtitle}</div>
        </div>

        <!-- Trail -->
        <div class="ml-auto text-card-foreground">
            <Icon name="mdi:arrow-top-right" size="24" />
        </div>
    </div>
</div>
