---
import BaseHead from "../components/BaseHead.astro";
import FloatActionButton from "../components/FloatActionButton.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { Image } from "astro:assets";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>

	<body>
		<div class="bg-grid"></div>

		<main
			class="mx-auto
				flex
				min-h-dvh
				max-w-6xl
				flex-col
				items-center
				justify-center
				gap-12
				px-6
				md:flex-row
				md:gap-12"
		>
			<!-- Left -->

			<section
				class="flex
					flex-col
					items-center
					text-center
					md:items-center
					md:text-left"
			>
				<!-- Avatar come from GitHub -->
				<div
					class="rounded-full border-4 border-primary/50 inline-block pointer-events-none"
				>
					<Image
						src="https://avatars.githubusercontent.com/u/88923783"
						alt="Avatar"
						inferSize
						loading="eager"
						class="h-28
						w-28
						rounded-full
						md:h-36
						md:w-36"
					/>
				</div>
				<h1 class="mt-6
						text-3xl
						font-bold">H2Sxxa</h1>
			</section>

			<!-- Right -->
			<section class="max-w-2xl
					text-center
					md:text-left">
				<h2 class="text-4xl
						font-bold
						md:text-5xl">
					Just Coding for Fun
				</h2>

				<p class="mt-6
						text-lg
						text-muted-foreground
						md:text-xl">
					Full-Stack Developer, Rustacean, Modder, Open-Source
					Builder...
				</p>
			</section>

			<FloatActionButton />
		</main>
	</body>
</html>

<style>
	.bg-grid {
		position: fixed;
		inset: 0;
		z-index: -1;

		background-image:
			linear-gradient(
				to right,
				color-mix(in oklab, var(--border) 20%, transparent) 1px,
				transparent 1px
			),
			linear-gradient(
				to bottom,
				color-mix(in oklab, var(--border) 20%, transparent) 1px,
				transparent 1px
			);

		background-size: 40px 40px;

		pointer-events: none;
	}
</style>
