---
import BaseLayout from "../layouts/BaseLayout.astro";
import { FRIENDS_LINKS } from "../consts";
---

<BaseLayout>
    <main>
        <div class="container mx-auto px-4 py-8">
            <h1 class="text-3xl font-bold mb-4 font-serif">Friends</h1>
            <p class="text-lg text-muted-foreground mb-6">
                Feel free to add your own blog link!
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {
                    FRIENDS_LINKS.map((friend) => (
                        <a
                            href={friend.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center p-4 bg-card rounded-lg hover:bg-accent transition-colors"
                        >
                            <img
                                src={friend.avatar}
                                alt={friend.title}
                                class="w-16 h-16 rounded-full mr-4"
                            />
                            <div>
                                <h2 class="text-xl font-semibold">
                                    {friend.title}
                                </h2>
                                <p class="text-card-foreground">
                                    {friend.intro}
                                </p>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>
    </main>
</BaseLayout>
